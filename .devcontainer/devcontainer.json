{
  "name": "trmnl-umami",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Forward the trmnlp preview server and open it automatically in the browser.
  "forwardPorts": [4567],
  "portsAttributes": {
    "4567": {
      "label": "trmnlp preview",
      "onAutoForward": "openBrowser"
    }
  },

  // Load Umami credentials from the .env file in the project root.
  // Copy .env.example to .env and fill in your values.
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env"],

  "customizations": {
    "vscode": {
      "extensions": [
        // Liquid syntax highlighting and formatting
        "sissel.shopify-liquid"
      ]
    }
  }
}
