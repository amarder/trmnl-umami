# Copy this file to .env and fill in your values.
# The devcontainer reads these from your host environment — export them in
# your shell profile (e.g. ~/.zshrc) or set them before opening the project.

# Bearer token for your Umami instance
UMAMI_API_KEY=your-api-key-here

# Hostname of your Umami instance (no https://)
# Self-hosted: umami.yourdomain.com
# Umami Cloud:  api.umami.is
UMAMI_HOSTNAME=umami.yourdomain.com

# API path prefix: "api" for self-hosted, "v1" for Umami Cloud
UMAMI_API_PREFIX=api

# UUID of the website you want to monitor
# Found in the Umami URL: /websites/<uuid>
UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# IANA time zone identifier — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
UMAMI_TIMEZONE=America/New_York
